generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Question {
  id         Int      @id @default(autoincrement())
  text       String
  answer     String
  answerHint String @default("")
  createdAt  DateTime @default(now())
}

model YesNoQuestion {
  id        Int      @id @default(autoincrement())
  text      String
  answer    String
  createdAt DateTime @default(now())
}

model GameState {
  id                 Int       @id @default(1)
  status             String    @default("WAITING")
  round              String    @default("NUMBERS")
  player1Name        String    @default("")
  player2Name        String    @default("")
  activeField        Int?
  claimedP1          String    @default("[]")
  claimedP2          String    @default("[]")
  winner             Int?
  updatedAt          DateTime  @updatedAt
  activePlayer        Int?
  unansweredFields    String    @default("[]")
  activeQuestionType  String?
  timerStartedAt      DateTime?
  questionAssignments String    @default("{}")
  activeFieldHint     String?
}
